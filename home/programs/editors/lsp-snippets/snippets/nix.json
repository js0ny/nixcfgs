{
  "let...in": {
    "prefix": "let",
    "body": ["let", "  ${2}", "in"],
    "description": "always block"
  },
  "traceVal": {
    "prefix": "trace",
    "body": ["lib.traceVal \"${1:message}\" ${2:value}"],
    "description": "traceVal"
  },
  "home.packages": {
    "prefix": "packages",
    "body": ["home.packages= with pkgs; [", "  $1", "];"]
  },
  "home.persist": {
    "prefix": "persist",
    "body": [
      "nixdots.persist.home = {",
      "  directories = [",
      "    \"$1\"",
      "  ];",
      "};"
    ]
  },
  "fakeSha": {
    "prefix": "fakeSha256",
    "body": ["sha256-AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA="]
  },
  "cfgenable": {
    "prefix": "cfgenable",
    "body": ["let", "  cfg = $1", "in", "lib.mkIf cfg.enable {", "$2", "}"]
  }
}
