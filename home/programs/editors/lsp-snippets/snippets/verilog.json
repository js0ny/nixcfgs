{
  "always": {
    "prefix": "always",
    "body": ["always @(${1}) begin", "  ${2}", "end"],
    "description": "always block"
  },
  "defstate": {
    "prefix": "defstate",
    "body": ["localparam S_${1:STATE_NAME} = ${2:STATE_VALUE};"],
    "description": "Define state parameter"
  },
  "begin": {
    "prefix": "begin",
    "body": ["begin", "  ${1}", "end"],
    "description": "begin...end block"
  },
  "if": {
    "prefix": "if",
    "body": ["if (${1}) begin", "\n${0}", "\nend"],
    "description": "If statement"
  },
  "if-else": {
    "prefix": "ife",
    "body": [
      "if (${1}) begin",
      "\n\t${2}",
      "\nend",
      "\nelse begin",
      "\n\t${3}",
      "\nend"
    ],
    "description": "If-else statement"
  },
  "else-if": {
    "prefix": "eif",
    "body": ["else if (${1}) begin", "\n${0}", "\nend"],
    "description": "else-if statement"
  },
  "else": {
    "prefix": "el",
    "body": ["else begin", "\n${0}", "\nend"],
    "description": "else-if statement"
  },
  "for": {
    "prefix": "for",
    "body": [
      "for (int ${2:i} = 0; $2 < ${1:count}; $2${3:++}) begin",
      "\n\t${4}",
      "\nend"
    ],
    "description": "For loop"
  }
}
