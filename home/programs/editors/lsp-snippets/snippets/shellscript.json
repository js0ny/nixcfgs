{
    "Case statement": {
        "prefix": "case",
        "body": "case $1 in\n\t$2)\n\t\t$3\n\t\t;;\n\t$4)\n\t\t$5\n\t\t;;\nesac",
        "description": "Case statement"
    },
    "Case statement with default/fallback": {
        "prefix": "cased",
        "body": "case $1 in\n\t$2)\n\t\t$3\n\t\t;;\n\t$4)\n\t\t$5\n\t\t;;\n\t*)\n\t\t$6\n\t\t;;\nesac",
        "description": "Case statement with default"
    },
    "Check if a file exists": {
        "prefix": "file",
        "body": "-f $1 && $2",
        "description": "Check if a file exists"
    },
    "Check if a directory exists": {
        "prefix": "dir",
        "body": "-d $1 && $2",
        "description": "Check if a directory exists"
    },
    "Check existence of a command": {
        "prefix": "cmd",
        "body": "command -v $1 > /dev/null 2>&1",
        "description": "Check existence of a command"
    },
    "Check existence of a command with if": {
        "prefix": "cmdif",
        "body": "if command -v $1 > /dev/null 2>&1; then\n\t$2\nfi",
        "description": "Check existence of a command with if"
    },
    "if statement": {
        "prefix": "if",
        "body": "if $1; then\n\t$2\nfi",
        "description": "if statement"
    },
    "if else statement": {
        "prefix": "ife",
        "body": "if $1; then\n\t$2\nelse\n\t$3\nfi",
        "description": "if else statement"
    },
    "if elif else statement": {
        "prefix": "ifel",
        "body": "if $1; then\n\t$2\nelif $3; then\n\t$4\nelse\n\t$5\nfi",
        "description": "if elif else statement"
    },
    "for loop": {
        "prefix": "for",
        "body": "for $1 in $2; do\n\t$3\ndone",
        "description": "for loop"
    },
    "bash associative array": {
        "prefix": "assocbash",
        "body": "declare -A $1\n$1=([${2:key1}]=${3:val1}\n[${4:key2}]=${5:val2})",
        "description": "associative array"
    },
    "zsh associative array": {
        "prefix": "assoczsh",
        "body": "typeset -A $1\n$1=([${2:key1}]=${3:val1}\n[${4:key2}]=${5:val2})",
        "description": "associative array"
    },
    "while loop": {
        "prefix": "while",
        "body": "while $1; do\n\t$2\ndone",
        "description": "while loop"
    },
    "Yes or no, default to yes": {
        "prefix": "yesnoyes",
        "body": [
            "read -p \"${1:[ACTION] Please choose}(Y/n)\" choice",
            "case \"$choice\" in",
            "  n|N )",
            "    $3",
            "    ;;",
            "  * )",
            "    $2",
            "    ;;",
            "esac"
        ],
        "description": "Yes or no, default to yes"
    },
    "Yes or no, default to no": {
        "prefix": "yesnono",
        "body": [
            "read -p \"${1:[ACTION] Please choose}(y/N)\" choice",
            "case \"$choice\" in",
            "  y|Y )",
            "    $2",
            "    ;;",
            "  * )",
            "    $3",
            "    ;;",
            "esac"
        ],
        "description": "Yes or no, default to no"
    },
    "Yes or no, no default": {
        "prefix": "yesno",
        "body": [
            "read -p \"${1:[ACTION] Please choose}(y/n)\" choice",
            "case \"$choice\" in",
            "  y|Y )",
            "    $2",
            "    ;;",
            "  n|N )",
            "    $3",
            "    ;;",
            "  * )",
            "    $4",
            "    ;;",
            "esac"
        ],
        "description": "Yes or no, no default"
    },
    "variable with fallback": {
        "prefix": "vard",
        "body": [
            "$1=\"${$1:-$2}\""
        ],
        "description": "variable with fallback"
    },
    "if variable is empty": {
        "prefix": "ifempty",
        "body": [
            "if [ -z \"$1\" ]; then",
            "  $2",
            "fi"
        ],
        "description": "if variable is empty"
    },
    "if variable is not empty": {
        "prefix": "ifnotempty",
        "body": [
            "if [ -n \"$1\" ]; then",
            "  $2",
            "fi"
        ],
        "description": "if variable is not empty"
    },
    "bashcheck": {
        "prefix": "#!bash",
        "body": [
            "#!/usr/bin/env bash",
            "# vim:ft=bash",
            "# shellcheck shell=bash",
            "$0"
        ],
        "description": "Bash shebang with shellcheck"
    },
    "shcheck": {
        "prefix": "#!sh",
        "body": [
            "#!/bin/sh",
            "# shellcheck shell=sh",
            "$0"
        ],
        "description": "Zsh shebang with shellcheck"
    },
    "shebang": {
        "prefix": "#!env",
        "body": [
            "#!/usr/bin/env $1",
            "# vim:ft=$1",
            "$0"
        ],
        "description": "Use /usr/bin/env to find the correct interpreter"
    },
    "comment": {
        "prefix": "###",
        "body": [
            "#######################################",
            "# ${1:Description of the function.}$0",
            "# Globals:",
            "#   ${3:MY_VAR}",
            "# Arguments:",
            "#   ${4:None}",
            "# Outputs:",
            "#   ${5:Output to STDOUT or STDERR.}",
            "# Returns:",
            "#   ${2: Description of the returned value.}",
            "#######################################"
        ],
        "description": "A shell comment block for functions, including description, globals, arguments, outputs, and returns. For functions without I/O, use the simple version of this snippet instead.\n\nYou can delete 'Globals'/'Arguments'/'Outputs' in functions with no input/output.\n\nIt doesn't includes, but accepts the optional keywords:\n  'See'\n  'Raises'"
    },
    "comment_simple": {
        "prefix": "##",
        "body": [
            "#######################################",
            "# ${1:Description of the function.}$0",
            "#######################################"
        ],
        "description": "A simple shell comment block for functions, with a description. Useful when the user prefers to add the other documentation tags manually."
    }
}
