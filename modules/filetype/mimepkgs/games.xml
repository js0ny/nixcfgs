<?xml version="1.0" encoding="UTF-8"?>
<mime-info xmlns="http://www.freedesktop.org/standards/shared-mime-info">

  <mime-type type="text/x-valve-vdf">
    <sub-class-of type="text/plain"/>
    <comment>Valve Data Format</comment>
    <comment xml:lang="zh_CN">Valve 数据格式</comment>
    <acronym>VDF</acronym>
    <glob pattern="*.vdf"/>
    <magic priority="50">
    <match type="string" value="&quot;AppState&quot;" offset="0:256"/>
    <match type="string" value="&quot;libraryfolders&quot;" offset="0:256"/>
    <match type="string" value="&quot;InstallScript&quot;" offset="0:256"/>
    <match type="string" value="\x00shortcuts\x00" offset="0"/>
    </magic>
  </mime-type>

  <mime-type type="application/x-balatro-jkr">
    <comment>Balatro Game Save File (Joker)</comment>
    <comment xml:lang="zh_CN">Balatro (小丑牌) Joker 游戏文件</comment>
    <acronym>JKR</acronym>
    <glob pattern="*.jkr"/>
  </mime-type>

  <mime-type type="text/x-pdx-descriptor">
    <comment>Paradox Mod Descriptor</comment>
    <comment xml:lang="zh_CN">Paradox Mod 描述文件</comment>
    <acronym>MOD</acronym>
    <sub-class-of type="text/plain"/>
    <glob pattern="*.mod" weight="80"/>
    <magic priority="80">
      <match value="name=" type="string" offset="0:200">
        <match value="supported_version=" type="string" offset="0:200">
          <match value="version=" type="string" offset="0:200">
            <match value="tags=" type="string" offset="0:200"/>
          </match>
        </match>
      </match>
    </magic>
  </mime-type>

  <mime-type type="application/x-ctr-importable-archive">
    <comment>Nintendo 3DS CTR Importable Archive</comment>
    <comment xml:lang="zh_CN">任天堂3DS CTR可导入档案 (CIA)</comment>
    <acronym>CIA</acronym>
    <glob pattern="*.cia"/>
    <magic priority="50">
      <match type="string" offset="0" value="\x20\x20\x00\x00\x00\x00\x00\x00"/>
    </magic>
  </mime-type>

  <mime-type type="application/x-godot-pack">
    <comment>Godot Engine Game Pack</comment>
    <comment xml:lang="zh_CN">Godot 引擎游戏包</comment>
    <acronym>PCK</acronym>
    <glob pattern="*.pck"/>
    <magic priority="50">
      <match type="string" value="GDPC" offset="0"/>
    </magic>
  </mime-type>

</mime-info>

